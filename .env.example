# --- Database ---
# Local dev (SQLite):
DATABASE_URL="file:./db/custom.db"

# Vercel / Postgres (uncomment and set to your Neon/Vercel/Supabase connection string):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- AI (Google Gemini) ---
# Get a key at https://aistudio.google.com/apikey
# On Vercel, set this in Project Settings → Environment Variables.
GEMINI_API_KEY=""

# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL="gemini-2.0-flash"

# --- Realtime (optional) ---
# Set to "true" ONLY when running the Socket.io mini-service locally.
# Leave unset / "false" on Vercel — the app uses TanStack Query polling (5s) instead.
# NEXT_PUBLIC_REALTIME_ENABLED="true"
